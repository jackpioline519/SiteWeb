@page "/contact"

<PageTitle>Contact - AquariumShop</PageTitle>

<section class="page-header">
    <div class="container-custom">
        <span class="eyebrow">Contact</span>
        <h1>Parlons de votre projet</h1>
        <p>
            Vous pouvez utiliser cette page pour afficher un formulaire, une adresse email,
            un numéro de téléphone ou une future demande de devis.
        </p>
    </div>
</section>

<section class="section-block">
    <div class="container-custom two-columns">
        <div class="content-card">
            <h2>Informations de contact</h2>
            <p><strong>Email :</strong> contact@aquariumshop.fr</p>
            <p><strong>Téléphone :</strong> À compléter</p>
        </div>

        <div class="content-card">
            <h2>Demande d’information</h2>
            <p>
                Tu pourras ensuite ajouter ici un vrai formulaire Blazor avec validation.
            </p>
        </div>
    </div>
</section>
