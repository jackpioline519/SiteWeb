@page "/"
@rendermode InteractiveServer
@inject ProduitService ProduitService

<PageTitle>Accueil - AquariumShop</PageTitle>

<section class="hero-section">
    <div class="container-custom hero-grid">
        <div>
            <span class="eyebrow">Surveillance intelligente pour aquarium</span>
            <h1>Contrôlez votre aquarium avec une solution claire, moderne et évolutive.</h1>
            <p>
                Découvrez un système pensé pour centraliser les mesures, simplifier le suivi du bac
                et proposer une base solide pour vos futurs équipements.
            </p>
            <div class="hero-actions">
                <a class="btn-primary-custom" href="/systeme">Découvrir le système</a>
                <a class="btn-secondary-custom" href="/rayons/capteurs">Voir les capteurs</a>
            </div>
        </div>

        <div class="hero-panel">
            <div class="hero-card">
                <h2>Une base commerciale simple</h2>
                <ul>
                    <li>Système complet</li>
                    <li>Capteurs vendus séparément</li>
                    <li>Rayons évolutifs</li>
                    <li>Offre pour particuliers et professionnels</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="section-block">
    <div class="container-custom">
        <div class="section-header">
            <span class="eyebrow">Nos rayons</span>
            <h2>Choisissez la solution adaptée à votre besoin</h2>
        </div>

        <div class="categories-grid">
            <CategoryCard Titre="Capteurs"
                          Description="Achetez les capteurs séparément selon votre installation."
                          Lien="/rayons/capteurs" />

            <CategoryCard Titre="Systèmes complets"
                          Description="Découvrez la solution centrale prête à intégrer."
                          Lien="/rayons/systemes-complets" />

            <CategoryCard Titre="Accessoires"
                          Description="Complétez votre installation avec les éléments utiles."
                          Lien="/rayons/accessoires" />
        </div>
    </div>
</section>

<section class="section-block section-alt">
    <div class="container-custom">
        <div class="section-header">
            <span class="eyebrow">Produits mis en avant</span>
            <h2>Une sélection pour démarrer</h2>
        </div>

        @if (_produitsVedettes.Count == 0)
        {
            <p>Aucun produit vedette disponible pour le moment.</p>
        }
        else
        {
            <div class="products-grid">
                @foreach (var produit in _produitsVedettes)
                {
                    <ProductCard Produit="produit" />
                }
            </div>
        }
    </div>
</section>

<section class="section-block">
    <div class="container-custom callout-banner">
        <div>
            <span class="eyebrow">Pour les passionnés et les professionnels</span>
            <h2>Une solution pensée pour évoluer avec vos besoins</h2>
            <p>
                Commencez avec un capteur ou adoptez directement un système complet,
                puis enrichissez votre installation au fil du temps.
            </p>
        </div>
        <a class="btn-primary-custom" href="/contact">Nous contacter</a>
    </div>
</section>

@code {
    private List<Produit> _produitsVedettes = new();

    protected override async Task OnInitializedAsync()
    {
        _produitsVedettes = await ProduitService.GetVedettesAsync();
    }
}
